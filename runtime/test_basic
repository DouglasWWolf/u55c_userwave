
#==============================================================================
#  test_basic - Runs a single userwave and waits for it to underflow
#==============================================================================
source api
test_name="basic_test"

# Load our userwave into queue 0
userwave_length=$(load_userwave 0 basic_test.csv)

# Fetch the address of the userwave recorder host buffer
record_buffer=$(axi REG_RECORD_BUFF_ADDR -dec -wide)

# Clear a few entries in the "recorded userwave" buffer
physram $record_buffer -clear 0xFF || exit 1

# Initialize everything to a known state
init

# How big is our userwave host buffer?
capacity=$(axi UW_Q0_HOST_CAPACITY -dec)

# We haven't provided any UWC.  Free space should match capacity
free=$(axi UW_Q0_UWC_HOST_FREE -dec)
expected=$capacity
if [ $free != $expected ]; then
    fatal "(1) UW_Q0_UWC_HOST_FREE should be 0x%X not 0x%X" $expected $free
fi

# There should be no errors
errors=$(axi UW_ERRORS -dec)
expected=0
if [ $errors != $expected ]; then
    fatal "(3) UW_ERRORS should be 0x%04X not 0x%04X" $expected $errors
fi


# Userwave engine should be halted
halted=$(is_halted)
expected=1
if [ $halted != $expected ]; then
    fatal "(4) Halt state should be %i not %i" $expected $halted
fi

# Tell the fetcher about the entire userwave
provide 0 $userwave_length

# There should be less free space now
free=$(axi UW_Q0_UWC_HOST_FREE -dec)
expected=$((capacity - userwave_length))
if [ $free != $expected ]; then
    fatal "(5) UW_Q0_UWC_HOST_FREE should be 0x%X not 0x%X" $expected $free
fi

# Start the userwave running without bothering to start the fetcher
ctl safe_run 0

# Wait a moment
sleep 1

# There should still be no errors
errors=$(axi UW_ERRORS -dec)
expected=0
if [ $errors != $expected ]; then
    fatal "(6) UW_ERRORS should be 0x%04X not 0x%04X" $expected $errors
fi

# Userwave engine should still be halted
halted=$(is_halted)
expected=1
if [ $halted != $expected ]; then
    fatal "(7) Halt state should be %i not %i" $expected $halted
fi

# Start the fetcher
start_fetcher 0

# Wait for underflow
if [ $(wait_underflow 20) -eq 0 ]; then
    fatal "(8) Underflow never happened!"
fi

# The entire capacity should be free now
free=$(axi UW_Q0_UWC_HOST_FREE -dec)
expected=$capacity
if [ $free != $expected ]; then
    fatal "(10) UW_Q0_UWC_HOST_FREE should be 0x%X not 0x%X" $expected $free
fi


# Indicate we passed the test
pass

#=======================================================================
# We're going to repeat that entire test, but this time we're going
# to start the fetcher *before* we start the engine
#=======================================================================
test_name="basic_test2"

# Clear a few entries in the "recorded userwave" buffer
physram $record_buffer -clear 0xFF || exit 1

# Initialize everything to a known state
init

# How big is our userwave host buffer?
capacity=$(axi UW_Q0_HOST_CAPACITY -dec)

# We haven't provided any UWC.  Free space should match capacity
free=$(axi UW_Q0_UWC_HOST_FREE -dec)
expected=$capacity
if [ $free != $expected ]; then
    fatal "(1) UW_Q0_UWC_HOST_FREE should be 0x%X not 0x%X" $expected $free
fi

# There should be no errors
errors=$(axi UW_ERRORS -dec)
expected=0
if [ $errors != $expected ]; then
    fatal "(3) UW_ERRORS should be 0x%04X not 0x%04X" $expected $errors
fi

# Userwave engine should be halted
halted=$(is_halted)
expected=1
if [ $halted != $expected ]; then
    fatal "(4) Halt state should be %i not %i" $expected $halted
fi

# Tell the fetcher about the entire userwave
provide 0 $userwave_length

# There should be less free space now
free=$(axi UW_Q0_UWC_HOST_FREE -dec)
expected=$((capacity - userwave_length))
if [ $free != $expected ]; then
    fatal "(5) UW_Q0_UWC_HOST_FREE should be 0x%X not 0x%X" $expected $free
fi

# Start the fetcher
start_fetcher 0

# Start the userwave engine
ctl safe_run 0

# There should still be no errors
errors=$(axi UW_ERRORS -dec)
expected=0
if [ $errors != $expected ]; then
    fatal "(6) UW_ERRORS should be 0x%04X not 0x%04X" $expected $errors
fi

# Userwave engine should NOT still be halted
halted=$(is_halted)
expected=0
if [ $halted != $expected ]; then
    fatal "(7) Halt state should be %i not %i" $expected $halted
fi

# Wait for underflow
if [ $(wait_underflow 20) -eq 0 ]; then
    fatal "(8) Underflow never happened!"
fi

# Underflow should be the only error
errors=$(axi UW_ERRORS -dec)
expected=$ERR_UNDERFLOW
if [ $errors != $expected ]; then
    fatal "(9) UW_ERRORS should be 0x%04X not 0x%04X" $expected $errors
fi

# The entire capacity should be free now
free=$(axi UW_Q0_UWC_HOST_FREE -dec)
expected=$capacity
if [ $free != $expected ]; then
    fatal "(10) UW_Q0_UWC_HOST_FREE should be 0x%X not 0x%X" $expected $free
fi

# Clear the underflow error
axi UW_ERRORS 0xFFFF_FFFF

# It should underflow again immediately
if [ $(wait_underflow 1) -eq 0 ]; then
    fatal "(11) Underflow never happened!"
fi

# Halt the engine
ctl safe_halt

# Userwave engine should be halted
halted=$(is_halted)
expected=1
if [ $halted != $expected ]; then
    fatal "(12) Halt state should be %i not %i" $expected $halted
fi

# Underflow should still be set
errors=$(axi UW_ERRORS -dec)
expected=$ERR_UNDERFLOW
if [ $errors != $expected ]; then
    fatal "(13 UW_ERRORS should be 0x%04X not 0x%04X" $expected $errors
fi

# Clear the underflow error
axi UW_ERRORS 0xFFFF_FFFF

# Wait a moment
sleep 1

# Since the engine is halted, underflow should not be set
errors=$(axi UW_ERRORS -dec)
expected=0
if [ $errors != $expected ]; then
    fatal "(14 UW_ERRORS should be 0x%04X not 0x%04X" $expected $errors
fi

# Indicate we passed the test
pass

# If we get here, all is well!
exit 0
